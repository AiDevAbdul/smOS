# smOS env template — DO NOT FILL THIS FILE.
#
# Real secrets live at ~/.config/smos/.env (chmod 600), outside the repo.
# Loader precedence: $SMOS_ENV_FILE → ~/.config/smos/.env → repo .env (dev fallback).
# To bootstrap: `cp .env.example ~/.config/smos/.env && chmod 600 ~/.config/smos/.env`
# then fill the values in ~/.config/smos/.env.
#
# ─── Meta API ──────────────────────────────────────────────────────────────
# System user token — generate in Business Manager > System Users
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_access_token

# ─── Supabase ──────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=postgresql://postgres:your_password@db.your_project_ref.supabase.co:5432/postgres
SUPABASE_SERVICE_KEY=your_supabase_service_role_jwt
SUPABASE_PASSWORD=your_supabase_db_password

# ─── Discord ───────────────────────────────────────────────────────────────
# Create two webhooks in your Discord server: Server Settings > Integrations > Webhooks
# ALERTS   — ops/digest channel (daily optimizer summaries, report rollups)
# APPROVALS — approval channel (budget guards, campaign launches, strategy briefs)
DISCORD_WEBHOOK_ALERTS=https://discord.com/api/webhooks/your-alerts-webhook-here
DISCORD_WEBHOOK_APPROVALS=https://discord.com/api/webhooks/your-approvals-webhook-here

# ─── Google (Drive + Gmail) ────────────────────────────────────────────────
# OAuth credentials JSON from Google Cloud Console
GDRIVE_CREDENTIALS={"client_id":"...","client_secret":"..."}
GMAIL_CREDENTIALS={"client_id":"...","client_secret":"..."}
GMAIL_FROM_ADDRESS=reports@yourdomain.com

# ─── Notion (optional) ─────────────────────────────────────────────────────
NOTION_TOKEN=secret_your_notion_token_here

# ─── Google Drive folder IDs ────────────────────────────────────────────────
# Root folder where per-client subfolders are created
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
