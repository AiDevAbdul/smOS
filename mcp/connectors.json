{
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest", "--supabase-url", "${SUPABASE_URL}", "--supabase-key", "${SUPABASE_SERVICE_KEY}"],
      "description": "smOS data persistence — clients, metrics, logs, reports"
    },
    "discord": {
      "command": "npx",
      "args": ["-y", "mcp-discord-webhooks"],
      "env": {
        "DISCORD_WEBHOOK_ALERTS": "${DISCORD_WEBHOOK_ALERTS}",
        "DISCORD_WEBHOOK_APPROVALS": "${DISCORD_WEBHOOK_APPROVALS}"
      },
      "description": "Notifications, daily digests, and approval requests"
    },
    "google-drive": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gdrive"],
      "env": {
        "GDRIVE_CREDENTIALS": "${GDRIVE_CREDENTIALS}"
      },
      "description": "Report storage and creative asset library"
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gmail"],
      "env": {
        "GMAIL_CREDENTIALS": "${GMAIL_CREDENTIALS}"
      },
      "description": "Weekly and monthly report delivery to clients"
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-notion"],
      "env": {
        "NOTION_API_KEY": "${NOTION_TOKEN}"
      },
      "description": "Strategy briefs and campaign documentation"
    }
  }
}
